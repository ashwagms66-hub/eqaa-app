{
  "expo": {
    "name": "إيقاع | Eqa'a",
    "slug": "eqaa-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "eqaa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ashwaq.eqaa",
      "buildNumber": "31",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSHealthShareUsageDescription": "Eqa'a reads your health data to generate your daily wellness score and personalized insights.",
        "NSHealthUpdateUsageDescription": "Eqa'a does not write to Apple Health."
      }
    },

    "android": {
      "package": "com.ashwaq.eqaa",
      "versionCode": 31,
      "adaptiveIcon": {
        "backgroundColor": "#090B1A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#090B1A",
          "dark": {
            "backgroundColor": "#0F1017"
          }
        }
      ],

      "expo-font",

      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],

      "@react-native-community/datetimepicker",

      [
        "expo-image-picker",
        {
          "cameraPermission": "Eqa'a uses your camera to scan gym equipment and identify exercises using AI.",
          "photosPermission": "Eqa'a accesses your photo library to scan gym equipment images.",
          "microphonePermission": false
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "7d3fe6de-bcb0-4df0-aeb3-9ac09ba8f83d"
      }
    }
  }
}
